                replace Y`yr'_Ch = `iwpe_rt_po_h`ht'_`yr'' - `iwpe_rt_pr_h`ht'_`yr'' in `row'
                if `iwpe_rt_pr_h`ht'_`yr'' > 0 {
                    replace Y`yr'_ChPct = ((`iwpe_rt_po_h`ht'_`yr'' - `iwpe_rt_pr_h`ht'_`yr'') / `iwpe_rt_pr_h`ht'_`yr'') * 100 in `row'
                }
            }
        }
        local row = `row' + 1
        replace Indicator = "  Share of those at IWP Employees risk (%)" in `row'
        foreach yr of local years {
            replace Y`yr'_pre = `shr_iwpe_pr_h`ht'_`yr'' in `row'
            replace Y`yr'_post = `shr_iwpe_po_h`ht'_`yr'' in `row'
        }
        local row = `row' + 2
    }
    
    keep if Indicator != ""
    
    foreach yr of local years {
        format Y`yr'_pre %15.2f
        format Y`yr'_post %15.2f
        format Y`yr'_Ch %15.2f
        format Y`yr'_ChPct %15.2f
    }
    
    capture mkdir "$output"
    
    local sheet_name "`label_`depvar''"
    
    if `sheet_num' == 1 {
        export excel "$output/Poverty_HH_Deprivation_PrePost.xlsx", replace sheet("`sheet_name'") firstrow(variables)
    }
    else {
        export excel "$output/Poverty_HH_Deprivation_PrePost.xlsx", sheetmodify sheet("`sheet_name'") firstrow(variables)
    }
    
    di "Sheet `sheet_name' created with all 4 poverty indicators"
}

