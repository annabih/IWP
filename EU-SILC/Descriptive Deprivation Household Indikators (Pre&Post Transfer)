*******************************************************************************************************************************************************************************************
*** Title: Poverty Analysis by Household Deprivation Indicators - Pre/Post Transfer - EU-SILC Austria 2017-2024
*** Indicators: 7 Household Items from Severe MSD (HS060, HS040, Arrears, HS050, HH050, HS110, HD080)
*** Date: 03.03.2026
*** Order: 1. AROP | 2. AROP w/o IWP | 3. IWP | 4. IWP Employees (LES==3)
*******************************************************************************************************************************************************************************************

clear all
set more off

use "D:\Data\AT_CROSS\SILC_CrossSec_AllYears_2015_2024.dta"
global output "D:\InWorkPoverty_SILC"

local years "2017 2018 2019 2020 2021 2022 2023 2024"

di _n "=== HOUSEHOLD DEPRIVATION ANALYSIS START (PRE/POST TRANSFER) ===" _n

*===============================================================================
* DESTRING VARIABLES
*===============================================================================
local numeric_vars "HX090 HY023 HX050 RB050 PB040 RX010 PX010 PL073 PL074 PL075 PL076 year PB150 PL040 PL040A HS060 HS040 HS011 HS021 HS031 HS050 HH050 HS110 HD080"

foreach var of local numeric_vars {
    capture confirm variable `var'
    if _rc == 0 {
        capture confirm string variable `var'
        if _rc == 0 {
            replace `var' = subinstr(`var', ",", ".", .)
            destring `var', replace force
        }
    }
}

*===============================================================================
* BASIC VARIABLES
*===============================================================================
capture confirm variable RB050
if _rc == 0 {
    gen dwt = RB050
}
else {
    gen dwt = PB040
}

capture confirm variable RX010
if _rc == 0 {
    gen age = RX010
}
else {
    gen age = PX010
}

gen months_worked = 0
foreach var in PL073 PL074 PL075 PL076 {
    capture confirm variable `var'
    if _rc == 0 {
        replace months_worked = months_worked + `var' if !missing(`var')
    }
}
replace months_worked = 12 if months_worked > 12 & !missing(months_worked)

* POST-TRANSFER INCOME (already equivalised)
gen eq_hh_ils_post = HX090

* PRE-TRANSFER INCOME (HY023 / equivalence scale = HX050)
gen eq_hh_ils_pre = HY023 / HX050 if !missing(HY023) & !missing(HX050) & HX050 > 0

drop if missing(eq_hh_ils_post) | missing(dwt) | missing(age)

*===============================================================================
* EMPLOYMENT STATUS (PL040 / PL040A)
*===============================================================================
di _n "=== Creating employment status ===" _n

gen emp_status = .
label variable emp_status "Employment status (PL040/PL040A)"

capture confirm variable PL040
if _rc == 0 {
    replace emp_status = PL040 if inrange(year, 2015, 2020)
    di "Employment status from PL040 used for 2015-2020"
}

capture confirm variable PL040A
if _rc == 0 {
    replace emp_status = PL040A if inrange(year, 2021, 2024)
    di "Employment status from PL040A used for 2021-2024"
}

quietly count if !missing(emp_status)
if r(N) > 0 {
    di "Employment status successfully created"
}
else {
    di as error "Warning: Employment status variable is empty"
}

gen byte employee = (emp_status == 3)
label variable employee "Employee (emp_status == 3)"

*===============================================================================
* HOUSEHOLD COMPOSITION AND TYPE
*===============================================================================
di _n "=== Creating household composition variables ===" _n

capture confirm variable id_hh
if _rc == 0 {
    gen hh_id = id_hh
    di "Using id_hh as household identifier"
}
else {
    capture confirm variable HB030
    if _rc == 0 {
        gen hh_id = HB030
        di "Using HB030 as household identifier"
    }
    else {
        capture confirm variable DB030
        if _rc == 0 {
            gen hh_id = DB030
            di "Using DB030 as household identifier"
        }
        else {
            di as error "No household ID found"
            exit 1
        }
    }
}

bysort year hh_id: egen n_adults = total(age >= 14)
bysort year hh_id: egen n_children = total(age < 14)
bysort year hh_id: egen hh_size = count(hh_id)

gen hh_type = .
replace hh_type = 1 if n_adults == 1 & n_children == 0
replace hh_type = 2 if n_adults == 1 & n_children == 1
replace hh_type = 3 if n_adults == 1 & n_children >= 2
replace hh_type = 4 if n_adults == 2 & n_children == 0
replace hh_type = 5 if n_adults == 2 & n_children == 1
replace hh_type = 6 if n_adults == 2 & n_children == 2
replace hh_type = 7 if n_adults == 2 & n_children >= 3
replace hh_type = 8 if n_adults >= 3 & n_children == 0
replace hh_type = 9 if n_adults >= 3 & n_children >= 1
replace hh_type = 10 if missing(hh_type)

label define hh_type_lbl 1 "1 Erwachsener" 2 "1 Erwachsener + 1 Kind" 3 "1 Erwachsener + 2+ Kinder" 4 "2 Erwachsene" 5 "2 Erwachsene + 1 Kind" 6 "2 Erwachsene + 2 Kinder" 7 "2 Erwachsene + 3+ Kinder" 8 "3+ Erwachsene" 9 "3+ Erwachsene mit Kindern" 10 "Sonstige"
label values hh_type hh_type_lbl
label variable hh_type "Household type"

tab hh_type, missing

*===============================================================================
* POVERTY THRESHOLD (based on POST-transfer income)
*===============================================================================
tempfile thresholds
tempname h
postfile `h' int year double median_eq_hh_ils pov_threshold_60 using `thresholds', replace

foreach yr of local years {
    quietly count if year==`yr'
    if r(N)==0 continue
    quietly _pctile eq_hh_ils_post [pw=dwt] if year==`yr', p(50)
    local median_val = r(r1)
    post `h' (`yr') (`median_val') (0.60*`median_val')
}
postclose `h'

merge m:1 year using `thresholds', nogen
replace pov_threshold_60 = round(pov_threshold_60, 1)

*===============================================================================
* POVERTY STATUS - PRE AND POST
* Order: 1. AROP | 2. AROP w/o IWP | 3. IWP | 4. IWP Employees
*===============================================================================

* 1. AROP
gen byte arop_post = (eq_hh_ils_post < pov_threshold_60) if !missing(pov_threshold_60)
gen byte arop_pre = (eq_hh_ils_pre < pov_threshold_60) if !missing(pov_threshold_60) & !missing(eq_hh_ils_pre)

* Worker definition
gen worker = (months_worked > 6 & age >= 18 & age <= 64)

* 3. IWP (all workers: employees + self-employed)
gen inwork_poor_post = (worker == 1 & arop_post == 1)
gen inwork_poor_pre = (worker == 1 & arop_pre == 1)

* 2. AROP without IWP
gen axi_post = (arop_post == 1 & inwork_poor_post == 0) if !missing(arop_post)
gen axi_pre = (arop_pre == 1 & inwork_poor_pre == 0) if !missing(arop_pre)
label variable axi_post "AROP without IWP (post-transfer)"
label variable axi_pre "AROP without IWP (pre-transfer)"

* 4. IWP Employees (LES==3 only)
gen byte iwp_emp_post = (inwork_poor_post == 1 & emp_status == 3)
gen byte iwp_emp_pre = (inwork_poor_pre == 1 & emp_status == 3)
label variable iwp_emp_post "IWP Employees post transfer (LES==3)"
label variable iwp_emp_pre "IWP Employees pre transfer (LES==3)"

*===============================================================================
* HOUSEHOLD DEPRIVATION VARIABLES (7 items from Severe MSD)
*===============================================================================
di _n "=== Creating household deprivation variables ===" _n

* 1. HS060 - Ability to face unexpected expenses (1=yes/can, 2=no/cannot)
capture confirm variable HS060
if _rc == 0 {
    gen dep_unexpected = .
    replace dep_unexpected = 0 if HS060 == 1
    replace dep_unexpected = 1 if HS060 == 2
    label variable dep_unexpected "Cannot face unexpected expenses"
    di "HS060 (unexpected expenses) created"
    tab dep_unexpected, missing
}
else {
    gen dep_unexpected = .
    di as error "WARNING: HS060 not found"
}

* 2. HS040 - Afford one week annual holiday (1=yes/can, 2=no/cannot)
capture confirm variable HS040
if _rc == 0 {
    gen dep_holiday = .
    replace dep_holiday = 0 if HS040 == 1
    replace dep_holiday = 1 if HS040 == 2
    label variable dep_holiday "Cannot afford one week holiday"
    di "HS040 (holiday) created"
    tab dep_holiday, missing
}
else {
    gen dep_holiday = .
    di as error "WARNING: HS040 not found"
}

* 3. Arrears - Composite: HS011 (mortgage/rent) + HS021 (utility) + HS031 (loan)
*    Each: 1=yes has arrears, 2=no arrears
*    Deprived if ANY of the three == 1
gen dep_arrears = .
label variable dep_arrears "Has arrears (mortgage/rent/utility/loan)"

capture confirm variable HS011
local has_hs011 = (_rc == 0)
capture confirm variable HS021
local has_hs021 = (_rc == 0)
capture confirm variable HS031
local has_hs031 = (_rc == 0)

if `has_hs011' | `has_hs021' | `has_hs031' {
    * Start with 0 (no arrears) if at least one variable is non-missing
    replace dep_arrears = 0 if (!missing(HS011) | !missing(HS021) | !missing(HS031))
    
    if `has_hs011' {
        replace dep_arrears = 1 if HS011 == 1
    }
    if `has_hs021' {
        replace dep_arrears = 1 if HS021 == 1
    }
    if `has_hs031' {
        replace dep_arrears = 1 if HS031 == 1
    }
    
    di "Arrears composite (HS011/HS021/HS031) created"
    tab dep_arrears, missing
}
else {
    di as error "WARNING: No arrears variables found (HS011/HS021/HS031)"
}

* 4. HS050 - Afford meal with meat/fish every second day (1=yes/can, 2=no/cannot)
capture confirm variable HS050
if _rc == 0 {
    gen dep_meal = .
    replace dep_meal = 0 if HS050 == 1
    replace dep_meal = 1 if HS050 == 2
    label variable dep_meal "Cannot afford meal with meat/fish every 2nd day"
    di "HS050 (meal) created"
    tab dep_meal, missing
}
else {
    gen dep_meal = .
    di as error "WARNING: HS050 not found"
}

* 5. HH050 - Keep home adequately warm (1=yes/can, 2=no/cannot)
capture confirm variable HH050
if _rc == 0 {
    gen dep_warm = .
    replace dep_warm = 0 if HH050 == 1
    replace dep_warm = 1 if HH050 == 2
    label variable dep_warm "Cannot keep home adequately warm"
    di "HH050 (warm) created"
    tab dep_warm, missing
}
else {
    gen dep_warm = .
    di as error "WARNING: HH050 not found"
}

* 6. HS110 - Access to a car/van (1=yes, 2=no cannot afford, 3=no other reason)
*    Enforced lack: deprived only if == 2 (cannot afford)
capture confirm variable HS110
if _rc == 0 {
    gen dep_car = .
    replace dep_car = 0 if HS110 == 1
    replace dep_car = 1 if HS110 == 2
    replace dep_car = 0 if HS110 == 3
    label variable dep_car "Cannot afford car/van"
    di "HS110 (car) created"
    tab dep_car, missing
}
else {
    gen dep_car = .
    di as error "WARNING: HS110 not found"
}

* 7. HD080 - Replace worn-out furniture (1=yes/can afford, 2=no/cannot afford, 3=no don't need)
*    Enforced lack: deprived only if == 2 (cannot afford)
capture confirm variable HD080
if _rc == 0 {
    gen dep_furniture = .
    replace dep_furniture = 0 if HD080 == 1
    replace dep_furniture = 1 if HD080 == 2
    replace dep_furniture = 0 if HD080 == 3
    label variable dep_furniture "Cannot afford replacing worn-out furniture"
    di "HD080 (furniture) created"
    tab dep_furniture, missing
}
else {
    gen dep_furniture = .
    di as error "WARNING: HD080 not found"
}

* Sex
capture confirm variable PB150
if _rc == 0 {
    gen sex = PB150
    label define sex_lbl 1 "Male" 2 "Female"
    label values sex sex_lbl
    di "Sex variable created successfully"
}
else {
    gen sex = .
    di as error "WARNING: PB150 not found, sex variable set to missing"
}

* SAVE ORIGINAL DATA
tempfile original_data
save `original_data', replace

*===============================================================================
* CALCULATE REFERENCE TOTALS (for percentages)
* Order: 1. AROP | 2. AROP w/o IWP | 3. IWP | 4. IWP Employees
*===============================================================================
di _n "=== Calculating reference totals ===" _n

foreach yr of local years {
    quietly count if year == `yr'
    if r(N) == 0 continue
    
    sum dwt if year == `yr'
    local ref_pop_`yr' = r(sum)
    
    * 1. AROP
    sum dwt if year == `yr' & arop_post == 1
    local ref_arop_po_`yr' = r(sum)
    sum dwt if year == `yr' & arop_pre == 1
    local ref_arop_pr_`yr' = r(sum)
    
    * 2. AROP without IWP
    sum dwt if year == `yr' & axi_post == 1
    local ref_axi_po_`yr' = r(sum)
    sum dwt if year == `yr' & axi_pre == 1
    local ref_axi_pr_`yr' = r(sum)
    
    * 3. IWP
    sum dwt if year == `yr' & worker == 1
    local ref_wrk_`yr' = r(sum)
    sum dwt if year == `yr' & worker == 1 & inwork_poor_post == 1
    local ref_iwp_po_`yr' = r(sum)
    sum dwt if year == `yr' & worker == 1 & inwork_poor_pre == 1
    local ref_iwp_pr_`yr' = r(sum)
    
    * 4. IWP Employees
    sum dwt if year == `yr' & worker == 1 & emp_status == 3
    local ref_emp_`yr' = r(sum)
    sum dwt if year == `yr' & worker == 1 & emp_status == 3 & iwp_emp_post == 1
    local ref_iwpe_po_`yr' = r(sum)
    sum dwt if year == `yr' & worker == 1 & emp_status == 3 & iwp_emp_pre == 1
    local ref_iwpe_pr_`yr' = r(sum)
}

*===============================================================================
* ANALYZE EACH HOUSEHOLD DEPRIVATION INDICATOR
*===============================================================================

local dep_vars "dep_unexpected dep_holiday dep_arrears dep_meal dep_warm dep_car dep_furniture"

local label_dep_unexpected "Unexpected_Exp"
local label_dep_holiday "Holiday"
local label_dep_arrears "Arrears"
local label_dep_meal "Meal"
local label_dep_warm "Warm"
local label_dep_car "Car"
local label_dep_furniture "Furniture"

local desc_dep_unexpected "face unexpected expenses"
local desc_dep_holiday "one week annual holiday"
local desc_dep_arrears "avoid arrears (mortgage/rent/utility/loan)"
local desc_dep_meal "meal with meat/fish every second day"
local desc_dep_warm "keep home adequately warm"
local desc_dep_car "access to a car/van"
local desc_dep_furniture "replace worn-out furniture"

* Household type labels
local hh_label_1 "1 Erwachsener"
local hh_label_2 "1 Erwachsener + 1 Kind"
local hh_label_3 "1 Erwachsener + 2+ Kinder"
local hh_label_4 "2 Erwachsene"
local hh_label_5 "2 Erwachsene + 1 Kind"
local hh_label_6 "2 Erwachsene + 2 Kinder"
local hh_label_7 "2 Erwachsene + 3+ Kinder"
local hh_label_8 "3+ Erwachsene"
local hh_label_9 "3+ Erwachsene mit Kindern"
local hh_label_10 "Sonstige"

local sheet_num = 0

foreach depvar of local dep_vars {
    
    use `original_data', clear
    
    capture confirm variable `depvar'
    if _rc != 0 {
        di as error "Variable `depvar' not found, skipping..."
        continue
    }
    
    quietly count if !missing(`depvar')
    if r(N) == 0 {
        di as error "Variable `depvar' has no data, skipping..."
        continue
    }
    
    local sheet_num = `sheet_num' + 1
    
    di _n "=== Analyzing: `depvar' (`desc_`depvar'') ===" _n
    
    *===========================================================================
    * OVERALL (not by sex) - PRE AND POST
    * Order: 1. AROP | 2. AROP w/o IWP | 3. IWP | 4. IWP Employees
    *===========================================================================
    
    foreach yr of local years {
        quietly count if year == `yr' & !missing(`depvar')
        if r(N) == 0 continue
        
        sum dwt if year == `yr' & !missing(`depvar')
        local tot_pop_`yr' = r(sum)
        local pct_pop_`yr' = (`tot_pop_`yr'' / `ref_pop_`yr'') * 100
        
        * 1. AROP
        sum dwt if year == `yr' & !missing(`depvar') & arop_post == 1
        local tot_arop_po_`yr' = r(sum)
        local pct_arop_po_`yr' = (`tot_arop_po_`yr'' / `ref_arop_po_`yr'') * 100
        
        sum dwt if year == `yr' & !missing(`depvar') & arop_pre == 1
        local tot_arop_pr_`yr' = r(sum)
        local pct_arop_pr_`yr' = (`tot_arop_pr_`yr'' / `ref_arop_pr_`yr'') * 100
        
        * 2. AROP without IWP
        sum dwt if year == `yr' & !missing(`depvar') & axi_post == 1
        local tot_axi_po_`yr' = r(sum)
        if `ref_axi_po_`yr'' > 0 {
            local pct_axi_po_`yr' = (`tot_axi_po_`yr'' / `ref_axi_po_`yr'') * 100
        }
        else {
            local pct_axi_po_`yr' = .
        }
        
        sum dwt if year == `yr' & !missing(`depvar') & axi_pre == 1
        local tot_axi_pr_`yr' = r(sum)
        if `ref_axi_pr_`yr'' > 0 {
            local pct_axi_pr_`yr' = (`tot_axi_pr_`yr'' / `ref_axi_pr_`yr'') * 100
        }
        else {
            local pct_axi_pr_`yr' = .
        }
        
        * 3. IWP
        sum dwt if year == `yr' & worker == 1 & !missing(`depvar')
        local tot_wrk_`yr' = r(sum)
        local pct_wrk_`yr' = (`tot_wrk_`yr'' / `ref_wrk_`yr'') * 100
        
        sum dwt if year == `yr' & worker == 1 & !missing(`depvar') & inwork_poor_post == 1
        local tot_iwp_po_`yr' = r(sum)
        if `ref_iwp_po_`yr'' > 0 {
            local pct_iwp_po_`yr' = (`tot_iwp_po_`yr'' / `ref_iwp_po_`yr'') * 100
        }
        else {
            local pct_iwp_po_`yr' = .
        }
        
        sum dwt if year == `yr' & worker == 1 & !missing(`depvar') & inwork_poor_pre == 1
        local tot_iwp_pr_`yr' = r(sum)
        if `ref_iwp_pr_`yr'' > 0 {
            local pct_iwp_pr_`yr' = (`tot_iwp_pr_`yr'' / `ref_iwp_pr_`yr'') * 100
        }
        else {
            local pct_iwp_pr_`yr' = .
        }
        
        * 4. IWP Employees
        sum dwt if year == `yr' & worker == 1 & emp_status == 3 & !missing(`depvar')
        local tot_emp_`yr' = r(sum)
        if `ref_emp_`yr'' > 0 {
            local pct_emp_`yr' = (`tot_emp_`yr'' / `ref_emp_`yr'') * 100
        }
        else {
            local pct_emp_`yr' = .
        }
        
        sum dwt if year == `yr' & worker == 1 & emp_status == 3 & !missing(`depvar') & iwp_emp_post == 1
        local tot_iwpe_po_`yr' = r(sum)
        if `ref_iwpe_po_`yr'' > 0 {
            local pct_iwpe_po_`yr' = (`tot_iwpe_po_`yr'' / `ref_iwpe_po_`yr'') * 100
        }
        else {
            local pct_iwpe_po_`yr' = .
        }
        
        sum dwt if year == `yr' & worker == 1 & emp_status == 3 & !missing(`depvar') & iwp_emp_pre == 1
        local tot_iwpe_pr_`yr' = r(sum)
        if `ref_iwpe_pr_`yr'' > 0 {
            local pct_iwpe_pr_`yr' = (`tot_iwpe_pr_`yr'' / `ref_iwpe_pr_`yr'') * 100
        }
        else {
            local pct_iwpe_pr_`yr' = .
        }
        
        * By category (0=can afford/no deprivation, 1=cannot afford/deprived)
        forvalues cat = 0/1 {
            
            quietly count if year == `yr' & `depvar' == `cat'
            if r(N) == 0 {
                local arop_rt_po_`cat'_`yr' = .
                local arop_rt_pr_`cat'_`yr' = .
                local shr_tot_`cat'_`yr' = .
                local shr_arop_po_`cat'_`yr' = .
                local shr_arop_pr_`cat'_`yr' = .
                local axi_rt_po_`cat'_`yr' = .
                local axi_rt_pr_`cat'_`yr' = .
                local shr_axi_po_`cat'_`yr' = .
                local shr_axi_pr_`cat'_`yr' = .
                local iwp_rt_po_`cat'_`yr' = .
                local iwp_rt_pr_`cat'_`yr' = .
                local shr_iwp_po_`cat'_`yr' = .
                local shr_iwp_pr_`cat'_`yr' = .
                local iwpe_rt_po_`cat'_`yr' = .
                local iwpe_rt_pr_`cat'_`yr' = .
                local shr_iwpe_po_`cat'_`yr' = .
                local shr_iwpe_pr_`cat'_`yr' = .
                continue
            }
            
            sum dwt if year == `yr' & `depvar' == `cat'
            local n_total_cat = r(sum)
            local shr_tot_`cat'_`yr' = (`n_total_cat' / `tot_pop_`yr'') * 100
            
            * --- 1. AROP ---
            sum arop_post [aw=dwt] if year == `yr' & `depvar' == `cat'
            local arop_rt_po_`cat'_`yr' = r(mean) * 100
            
            sum dwt if year == `yr' & `depvar' == `cat' & arop_post == 1
            local n_arop_post_cat = r(sum)
            if `tot_arop_po_`yr'' > 0 {
                local shr_arop_po_`cat'_`yr' = (`n_arop_post_cat' / `tot_arop_po_`yr'') * 100
            }
            else {
                local shr_arop_po_`cat'_`yr' = .
            }
            
            sum arop_pre [aw=dwt] if year == `yr' & `depvar' == `cat'
            local arop_rt_pr_`cat'_`yr' = r(mean) * 100
            
            sum dwt if year == `yr' & `depvar' == `cat' & arop_pre == 1
            local n_arop_pre_cat = r(sum)
            if `tot_arop_pr_`yr'' > 0 {
                local shr_arop_pr_`cat'_`yr' = (`n_arop_pre_cat' / `tot_arop_pr_`yr'') * 100
            }
            else {
                local shr_arop_pr_`cat'_`yr' = .
            }
            
            * --- 2. AROP without IWP ---
            sum axi_post [aw=dwt] if year == `yr' & `depvar' == `cat'
            local axi_rt_po_`cat'_`yr' = r(mean) * 100
            
            sum dwt if year == `yr' & `depvar' == `cat' & axi_post == 1
            local n_axi_post_cat = r(sum)
            if `tot_axi_po_`yr'' > 0 {
                local shr_axi_po_`cat'_`yr' = (`n_axi_post_cat' / `tot_axi_po_`yr'') * 100
            }
            else {
                local shr_axi_po_`cat'_`yr' = .
            }
            
            sum axi_pre [aw=dwt] if year == `yr' & `depvar' == `cat'
            local axi_rt_pr_`cat'_`yr' = r(mean) * 100
            
            sum dwt if year == `yr' & `depvar' == `cat' & axi_pre == 1
            local n_axi_pre_cat = r(sum)
            if `tot_axi_pr_`yr'' > 0 {
                local shr_axi_pr_`cat'_`yr' = (`n_axi_pre_cat' / `tot_axi_pr_`yr'') * 100
            }
            else {
                local shr_axi_pr_`cat'_`yr' = .
            }
            
            * --- 3. IWP ---
            quietly count if year == `yr' & `depvar' == `cat' & worker == 1
            if r(N) > 0 {
                sum inwork_poor_post [aw=dwt] if year == `yr' & `depvar' == `cat' & worker == 1
                local iwp_rt_po_`cat'_`yr' = r(mean) * 100
                
                sum dwt if year == `yr' & `depvar' == `cat' & worker == 1 & inwork_poor_post == 1
                local n_iwp_post_cat = r(sum)
                if `tot_iwp_po_`yr'' > 0 {
                    local shr_iwp_po_`cat'_`yr' = (`n_iwp_post_cat' / `tot_iwp_po_`yr'') * 100
                }
                else {
                    local shr_iwp_po_`cat'_`yr' = .
                }
                
                sum inwork_poor_pre [aw=dwt] if year == `yr' & `depvar' == `cat' & worker == 1
                local iwp_rt_pr_`cat'_`yr' = r(mean) * 100
                
                sum dwt if year == `yr' & `depvar' == `cat' & worker == 1 & inwork_poor_pre == 1
