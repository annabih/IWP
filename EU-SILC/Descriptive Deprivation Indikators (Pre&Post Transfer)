        format Y`yr'_pre %15.2f
        format Y`yr'_post %15.2f
        format Y`yr'_Ch %15.2f
        format Y`yr'_ChPct %15.2f
    }
    
    export excel "$output/Poverty_RX_Indicators_PrePost.xlsx", sheetmodify sheet("AROPE_Detail") firstrow(variables)
    
