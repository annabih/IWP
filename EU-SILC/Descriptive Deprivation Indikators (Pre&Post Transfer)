* PART C: RX070 DETAILED AROPE BREAKDOWN (Supplementary Sheet)
* Values: 0, 1, 10, 11, 100, 101, 110, 111
* Shows poverty rates for each AROPE combination
*===============================================================================
*===============================================================================

di _n "=== PART C: RX070 Detailed AROPE Breakdown ===" _n

use `original_data', clear

capture confirm variable rx070_detail
if _rc != 0 {
    di as error "rx070_detail not found, skipping detailed AROPE"
}
else {

    quietly count if !missing(rx070_detail)
    if r(N) == 0 {
        di as error "rx070_detail has no data, skipping"
    }
    else {

    * Labels for RX070 detailed values
    * Format: ARP(100s) / Sev.Mat.Dep(10s) / Low.WI(1s)
    local arope_vals "0 1 10 11 100 101 110 111"
    local arope_label_0 "Not ARP / Not SMD / No Low WI"
    local arope_label_1 "Not ARP / Not SMD / Low WI"
    local arope_label_10 "Not ARP / SMD / No Low WI"
    local arope_label_11 "Not ARP / SMD / Low WI"
    local arope_label_100 "ARP / Not SMD / No Low WI"
    local arope_label_101 "ARP / Not SMD / Low WI"
    local arope_label_110 "ARP / SMD / No Low WI"
    local arope_label_111 "ARP / SMD / Low WI"
    
    foreach yr of local years {
        quietly count if year == `yr' & !missing(rx070_detail)
        if r(N) == 0 continue
        
        sum dwt if year == `yr' & !missing(rx070_detail)
        local tot_pop_`yr' = r(sum)
        
        foreach val of local arope_vals {
            
            local shr_`val'_`yr' = .
            local arop_rt_po_`val'_`yr' = .
            local arop_rt_pr_`val'_`yr' = .
            local iwp_rt_po_`val'_`yr' = .
            local iwp_rt_pr_`val'_`yr' = .
            
            quietly count if year == `yr' & rx070_detail == `val'
            if r(N) == 0 continue
            
            sum dwt if year == `yr' & rx070_detail == `val'
            local n_val = r(sum)
            local shr_`val'_`yr' = (`n_val' / `tot_pop_`yr'') * 100
            
            sum arop_post [aw=dwt] if year == `yr' & rx070_detail == `val'
            local arop_rt_po_`val'_`yr' = r(mean) * 100
            
            sum arop_pre [aw=dwt] if year == `yr' & rx070_detail == `val'
            local arop_rt_pr_`val'_`yr' = r(mean) * 100
            
            quietly count if year == `yr' & rx070_detail == `val' & worker == 1
            if r(N) > 0 {
                sum inwork_poor_post [aw=dwt] if year == `yr' & rx070_detail == `val' & worker == 1
                local iwp_rt_po_`val'_`yr' = r(mean) * 100
                sum inwork_poor_pre [aw=dwt] if year == `yr' & rx070_detail == `val' & worker == 1
                local iwp_rt_pr_`val'_`yr' = r(mean) * 100
            }
        }
    }
    
    * Create Excel sheet
    clear
    set obs 100
    
    gen str100 Indicator = ""
    foreach yr of local years {
        gen double Y`yr'_pre = .
        gen double Y`yr'_post = .
        gen double Y`yr'_Ch = .
        gen double Y`yr'_ChPct = .
    }
    
    local row = 1
    
    replace Indicator = "=== RX070 AROPE DETAILED BREAKDOWN ===" in `row'
    local row = `row' + 1
    replace Indicator = "Format: ARP (100s) / Sev.Mat.Dep (10s) / Low Work Int (1s)" in `row'
    local row = `row' + 1
    replace Indicator = "" in `row'
    local row = `row' + 1
    
    foreach val of local arope_vals {
        
        replace Indicator = "=== RX070 = `val': `arope_label_`val'' ===" in `row'
        local row = `row' + 1
        replace Indicator = "" in `row'
        local row = `row' + 1
        
        replace Indicator = "  Share of population (%)" in `row'
        foreach yr of local years {
            replace Y`yr'_post = `shr_`val'_`yr'' in `row'
        }
        local row = `row' + 1
        
        replace Indicator = "  AROP rate (%)" in `row'
        foreach yr of local years {
            replace Y`yr'_pre = `arop_rt_pr_`val'_`yr'' in `row'
            replace Y`yr'_post = `arop_rt_po_`val'_`yr'' in `row'
            if `arop_rt_pr_`val'_`yr'' != . & `arop_rt_po_`val'_`yr'' != . {
                replace Y`yr'_Ch = `arop_rt_po_`val'_`yr'' - `arop_rt_pr_`val'_`yr'' in `row'
                if `arop_rt_pr_`val'_`yr'' > 0 {
                    replace Y`yr'_ChPct = ((`arop_rt_po_`val'_`yr'' - `arop_rt_pr_`val'_`yr'') / `arop_rt_pr_`val'_`yr'') * 100 in `row'
                }
            }
        }
        local row = `row' + 1
        
        replace Indicator = "  IWP rate (workers only) (%)" in `row'
