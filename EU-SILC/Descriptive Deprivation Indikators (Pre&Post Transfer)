            replace Y`yr'_pre = `iwp_rt_pr_`val'_`yr'' in `row'
            replace Y`yr'_post = `iwp_rt_po_`val'_`yr'' in `row'
            if `iwp_rt_pr_`val'_`yr'' != . & `iwp_rt_po_`val'_`yr'' != . {
                replace Y`yr'_Ch = `iwp_rt_po_`val'_`yr'' - `iwp_rt_pr_`val'_`yr'' in `row'
